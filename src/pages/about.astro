---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Alejandro" description="About Alejandro F. Zegarra V.">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="Sobre mí"
				tagline="Desarrollador Full Stack | React, Laravel, MySQL Construyo sistemas web que automatizan procesos y mejoran la eficiencia."
			>
				<img
					width="1553"
					height="873"
					src="/assets/backgrounds/11.png"
					alt="Alejandro Zegarra - Full Stack Developer"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Perfil</h2>
				<div class="content">
					<p>
						Desarrollador Full Stack con experiencia en PHP, Laravel, React y MySQL,
						enfocado en la creación de sistemas web que automatizan procesos y mejoran
						la eficiencia operativa.
					</p>
					<p>
						He desarrollado aplicaciones completas con autenticación, roles de usuario,
						APIs REST y gestión de bases de datos, participando en proyectos reales
						donde optimicé flujos administrativos y mejoré la organización de la información.
					</p>
					<p>
						Me especializo en construir soluciones funcionales, escalables y alineadas
						a necesidades de negocio, con enfoque en rendimiento y buenas prácticas.
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Educación</h2>
				<div class="content">
					<p>Estudiante de Ingeniería de Software – UPC</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p><strong>Frontend:</strong> React, JavaScript, HTML, CSS</p>
					<p><strong>Backend:</strong> PHP, Laravel, APIs REST</p>
					<p><strong>Base de datos:</strong> MySQL</p>
					<p><strong>Herramientas:</strong> Git, GitHub</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
